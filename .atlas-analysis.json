  "keyFeatures": [
    "SM-2 spaced repetition algorithm with adaptive scheduling",
    "LeetCode problem auto-fetch with title and difficulty",
    "Concept library linking problems to algorithm topics",
    "Dashboard with streak tracking and recall quality metrics",
    "Full-stack architecture with Next.js and Go backend",
    "Clerk authentication with Google OAuth support"
  ],
  "publicApiSurface": [
    "POST /api/v1/problems - Create a new problem",
    "GET /api/v1/concepts - List all algorithm concepts",
    "GET /api/v1/reviews/queue - Get problems due for review",
    "POST /api/v1/reviews/:entity_type/:entity_id/log - Log review result",
    "GET /api/v1/leetcode/fetch - Fetch LeetCode problem metadata",
    "GET /api/v1/metrics/dashboard - Get dashboard metrics",
    "GET /api/v1/metrics/recall - Get recall quality over time",
    "GET /api/v1/metrics/mastery - Get topic-level mastery stats"
  ]
